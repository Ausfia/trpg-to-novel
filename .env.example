# OpenAI-compatible 接口配置（DeepSeek / OpenAI / OpenRouter / Kimi / Claude 经 LiteLLM 皆可）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 各阶段使用的模型（按阶段分配 — 便宜模型跑分段、贵模型跑章节起草与审稿）
STAGE_MODEL_SEGMENT=deepseek-chat
STAGE_MODEL_CHAPTER_DETECT=deepseek-chat
STAGE_MODEL_DRAFT=deepseek-reasoner
STAGE_MODEL_REVIEW=deepseek-chat

# 章节生成的扩充倍率（原始日志正文字数 → 章节稿字数）目标
TARGET_EXPANSION_RATIO=2.5

# 场景切分时间间隙阈值（分钟）— 大于此值视为场景边界候选
SCENE_GAP_MINUTES=5
